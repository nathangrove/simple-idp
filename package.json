{
    "name": "simple-idp",
    "version": "0.0.1",
    "description": "A simple IDP that supports OIDC, oAuth, and SAML",
    "engines": {
        "node": ">=14 <17"
    },
    "scripts": {
        "start": "ts-node -r tsconfig-paths/register -r dotenv/config src/index",
        "dev": "NODE_ENV=development nodemon --config restart.json",
        "clean": "rm -rf coverage build tmp",
        "prebuild": "npm run lint",
        "build": "tsc -p tsconfig.build.json",
        "build:watch": "tsc -w -p tsconfig.build.json",
        "lint": "eslint --fix . --ext .ts,.tsx",
        "test": "jest"
    },
    "author": "Nathan Grove <nathan@nathangrove.com>",
    "license": "Apache-2.0",
    "dependencies": {
        "bcrypt": "^5.0.1",
        "connect-redis": "^6.1.3",
        "cookie-parser": "^1.4.6",
        "express": "^4.17.1",
        "express-session": "^1.17.2",
        "jsonwebtoken": "^8.5.1",
        "lodash": "^4.17.21",
        "module-alias": "^2.2.2",
        "mongodb": "^4.5.0",
        "node-jose": "^2.1.1",
        "redis": "^4.1.0",
        "tslib": "~2.3.0",
        "uuid": "^8.3.2",
        "winston": "^3.3.3",
        "xml2js": "^0.4.23"
    },
    "devDependencies": {
        "@tsconfig/recommended": "^1.0.1",
        "@types/bcrypt": "^5.0.0",
        "@types/cookie-parser": "^1.4.3",
        "@types/express": "^4.17.13",
        "@types/express-session": "^1.17.4",
        "@types/jest": "^26.0.24",
        "@types/lodash": "^4.14.182",
        "@types/mongodb": "^4.0.7",
        "@types/node": "^17.0.24",
        "@types/node-jose": "^1.1.10",
        "@types/redis": "^4.0.11",
        "@types/uuid": "^8.3.4",
        "@types/xml2js": "^0.4.9",
        "@typescript-eslint/eslint-plugin": "~4.28.2",
        "@typescript-eslint/parser": "~4.28.2",
        "dotenv": "^10.0.0",
        "eslint": "~7.30.0",
        "eslint-config-prettier": "~8.3.0",
        "eslint-plugin-jest": "~24.3.6",
        "jest": "^27.5.1",
        "jest-html-reporter": "^3.4.1",
        "nodemon": "^2.0.12",
        "prettier": "~2.3.2",
        "rimraf": "^3.0.2",
        "supertest": "^6.1.5",
        "ts-jest": "^27.0.3",
        "ts-node": "^10.2.0",
        "ts-node-dev": "^1.1.8",
        "tsconfig-paths": "^3.10.1",
        "tsutils": "~3.21.0",
        "typescript": "~4.3.5"
    }
}
